{
  "expo": {
    "name": "IsdaHub",
    "slug": "isdahub",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "isdahub",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A6E4F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.isdahub.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A6E4F"
      },
      "package": "com.isdahub.app",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "IsdaHub needs access to your photos to upload catch photos."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d3b19f67-df38-4cd7-a288-788798ad852f"
      }
    }
  }
}
